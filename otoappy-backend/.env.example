# Copy this file to .env and fill in real values
# IMPORTANT: Do NOT commit your real .env to git.

PORT=4000

# Set your OpenAI API key in your local environment.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# CORS origin allowed for the extension/app.
# Use '*' for local testing, or restrict to your exact origin in production.
CORS_ORIGIN=*

# Required for user authentication tokens (generate via: openssl rand -hex 32)
JWT_SECRET=

# Required for encrypting stored user API keys (generate via: openssl rand -hex 32)
ENCRYPTION_KEY=
