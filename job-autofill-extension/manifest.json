{
  "manifest_version": 3,
  "name": "Job Application Autofill+",
  "version": "3.0.0",
  "description": "Autofill job applications + AI cover letters.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Autofill+"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["field-mappings.json"],
      "matches": ["*://*/*"]
    }
  ]
}

